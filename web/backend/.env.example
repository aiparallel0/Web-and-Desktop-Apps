# =============================================================================
# FLASK APPLICATION SETTINGS
# =============================================================================

# Environment mode: development, production, or testing
FLASK_ENV=development

# Enable/disable Flask debug mode (should be False in production)
FLASK_DEBUG=False
DEBUG=False

# Secret key for Flask session management and CSRF protection
# IMPORTANT: Generate a strong random secret for production!
# Example: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# Server host and port configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Enable serverless mode (e.g., for AWS Lambda, Google Cloud Functions)
SERVERLESS=False

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database connection URL
# SQLite (default for development): sqlite:///./receipt_extractor.db
# PostgreSQL: postgresql://user:password@localhost:5432/dbname
# MySQL: mysql://user:password@localhost:3306/dbname
DATABASE_URL=sqlite:///./receipt_extractor.db

# Force SQLite usage (overrides DATABASE_URL if set to true)
USE_SQLITE=True

# Testing mode (uses in-memory database)
TESTING=False

# Database connection pool settings (for non-SQLite databases)
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Enable SQL query logging (useful for debugging, disable in production)
SQL_ECHO=False

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT secret key for token signing
# IMPORTANT: Must be at least 32 characters in production!
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-this-secret-in-production-use-env-var-min-32-chars

# Token expiration times (in seconds)
JWT_ACCESS_TOKEN_EXPIRES=900        # 15 minutes
JWT_REFRESH_TOKEN_EXPIRES=2592000   # 30 days

# =============================================================================
# STRIPE PAYMENT INTEGRATION
# =============================================================================

# Stripe API keys (get from https://dashboard.stripe.com/apikeys)
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# Stripe webhook secret (for webhook signature verification)
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# CLOUD STORAGE - AWS S3
# =============================================================================

# AWS credentials and S3 bucket configuration
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
# AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1

# =============================================================================
# CLOUD STORAGE - GOOGLE DRIVE
# =============================================================================

# Google OAuth credentials (from Google Cloud Console)
# GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_client_secret
# GOOGLE_DRIVE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# =============================================================================
# CLOUD STORAGE - DROPBOX
# =============================================================================

# Dropbox app credentials (from Dropbox App Console)
# DROPBOX_APP_KEY=your_app_key
# DROPBOX_APP_SECRET=your_app_secret

# =============================================================================
# CLOUD TRAINING PROVIDERS
# =============================================================================

# Hugging Face API token (for model downloads and inference)
# HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx

# Replicate API token (for cloud-based model inference)
# REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxx

# RunPod API key (for GPU cloud training)
# RUNPOD_API_KEY=xxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================

# OpenTelemetry configuration (for distributed tracing)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=receipt-extractor

# Sentry configuration (for error tracking and monitoring)
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxx
SENTRY_ENVIRONMENT=development

# =============================================================================
# CIRCULAR EXCHANGE FRAMEWORK
# =============================================================================

# Enable/disable the Circular Exchange Framework
CIRCULAR_EXCHANGE_ENABLED=True

# Circular Exchange logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
CIRCULAR_EXCHANGE_LOG_LEVEL=INFO

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

# Redis connection settings (for caching and message queuing)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Redis password (if authentication is enabled)
# REDIS_PASSWORD=your_redis_password

# =============================================================================
# OCR & MODEL CONFIGURATION
# =============================================================================

# Directory for caching downloaded models
MODEL_CACHE_DIR=./models

# Path to Tesseract OCR executable (if not in system PATH)
# Windows example: C:/Program Files/Tesseract-OCR/tesseract.exe
# Linux example: /usr/bin/tesseract
# TESSERACT_CMD=/usr/bin/tesseract

# Maximum number of models to keep loaded in memory
MAX_LOADED_MODELS=3

# =============================================================================
# FILE UPLOAD SETTINGS
# =============================================================================

# Comma-separated list of allowed file extensions
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,bmp,tiff,webp,pdf

# Maximum file upload size in bytes (default: 16 MB)
MAX_CONTENT_LENGTH=16777216

# Directory for storing uploaded files
UPLOAD_FOLDER=./uploads

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: text or json
LOG_FORMAT=text

# Optional: Path to log file (logs to console if not specified)
# LOG_FILE=./logs/app.log

# =============================================================================
# CORS SETTINGS
# =============================================================================

# Allowed CORS origins (comma-separated list or * for all)
# Examples:
#   - Allow all: *
#   - Specific origins: http://localhost:3000,https://example.com
CORS_ORIGINS=*

# Allow credentials in CORS requests
CORS_ALLOW_CREDENTIALS=True

# =============================================================================
# RATE LIMITING
# =============================================================================

# Enable/disable rate limiting
RATE_LIMIT_ENABLED=False

# Maximum requests per minute per IP address
RATE_LIMIT_PER_MINUTE=100
