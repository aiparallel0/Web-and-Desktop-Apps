# =============================================================================
# Receipt Extractor - PRODUCTION Environment Configuration
# =============================================================================
# 
# This file contains ALL variables needed for production deployment to Railway
# 
# SETUP INSTRUCTIONS:
# 1. Run: python generate-secrets.py
# 2. Copy output and paste SECRET_KEY and JWT_SECRET below
# 3. Fill in Stripe keys from dashboard.stripe.com
# 4. Fill in SendGrid API key from sendgrid.com
# 5. Copy all variables to Railway dashboard → Variables → Raw Editor
# 
# =============================================================================

# =============================================================================
# APPLICATION SETTINGS (Required)
# =============================================================================

FLASK_ENV=production
FLASK_DEBUG=False
DEBUG=False

# Your Railway app URL (update after deployment)
# Example: https://receipt-extractor-production.railway.app
BASE_URL=https://your-app-name.railway.app

# =============================================================================
# SECRETS (Required - Generate with: python generate-secrets.py)
# =============================================================================

# 🚨 CRITICAL: Replace these with output from generate-secrets.py
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET_KEY_FROM_SCRIPT
JWT_SECRET=REPLACE_WITH_GENERATED_JWT_SECRET_FROM_SCRIPT

# JWT Token Expiration
JWT_ACCESS_TOKEN_EXPIRES=900           # 15 minutes
JWT_REFRESH_TOKEN_EXPIRES=2592000      # 30 days

# =============================================================================
# DATABASE (Automatically configured by Railway PostgreSQL)
# =============================================================================

# Railway automatically sets DATABASE_URL when you add PostgreSQL service
# No need to set manually - just add PostgreSQL in Railway dashboard
# DATABASE_URL=postgresql://...  (auto-configured)

USE_SQLITE=false
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# =============================================================================
# STRIPE PAYMENT INTEGRATION (Required for Revenue)
# =============================================================================

# Step 1: Get from https://dashboard.stripe.com/apikeys
# Step 2: For testing, use keys starting with sk_test_ and pk_test_
# Step 3: After verification, switch to sk_live_ and pk_live_

# TEST MODE (use these while waiting for Stripe verification):
STRIPE_SECRET_KEY=sk_test_PASTE_YOUR_TEST_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_PASTE_YOUR_TEST_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_PASTE_YOUR_WEBHOOK_SECRET_HERE

# LIVE MODE (switch to these after Stripe verification):
# STRIPE_SECRET_KEY=sk_live_PASTE_YOUR_LIVE_KEY_HERE
# STRIPE_PUBLISHABLE_KEY=pk_live_PASTE_YOUR_LIVE_KEY_HERE
# STRIPE_WEBHOOK_SECRET=whsec_PASTE_YOUR_LIVE_WEBHOOK_SECRET_HERE

# Product Price IDs (create products in Stripe Dashboard)
# Create in: https://dashboard.stripe.com/products
# Pro Plan: Create product with $19/month recurring price
# Business Plan: Create product with $49/month recurring price
STRIPE_PRICE_ID_PRO=price_PASTE_YOUR_PRO_PRICE_ID_HERE
STRIPE_PRICE_ID_BUSINESS=price_PASTE_YOUR_BUSINESS_PRICE_ID_HERE

# =============================================================================
# EMAIL SERVICE (Required for User Communication)
# =============================================================================

# SendGrid (Recommended - Free tier: 100 emails/day)
# Get API key from: https://app.sendgrid.com/settings/api_keys

EMAIL_SERVICE=sendgrid
ENABLE_EMAIL_AUTOMATION=true

SENDGRID_API_KEY=SG.PASTE_YOUR_API_KEY_HERE
SENDGRID_FROM_EMAIL=noreply@yourdomain.com  # Must be verified in SendGrid
SENDGRID_FROM_NAME=Receipt Extractor

# =============================================================================
# FEATURE FLAGS (Recommended Settings for Production)
# =============================================================================

# Core Features (Enabled)
ENABLE_CEFR=false                    # Circular Exchange Framework (experimental)
ENABLE_BATCH_PROCESSING=true         # Allow batch receipt processing
ENABLE_API_ACCESS=true               # Enable REST API endpoints

# Cloud Storage (Disabled - Optional)
ENABLE_S3_STORAGE=false              # AWS S3 integration
ENABLE_GDRIVE_STORAGE=false          # Google Drive integration  
ENABLE_DROPBOX_STORAGE=false         # Dropbox integration

# Cloud Training (Disabled - Optional)
ENABLE_HF_TRAINING=false             # HuggingFace training
ENABLE_REPLICATE_TRAINING=false      # Replicate training
ENABLE_RUNPOD_TRAINING=false         # RunPod GPU training

# =============================================================================
# OPTIONAL: Analytics & Monitoring
# =============================================================================

# Google Analytics (Optional - for website analytics)
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Facebook Pixel (Optional - for ad tracking)
# FACEBOOK_PIXEL_ID=123456789

# Sentry Error Tracking (Optional - for error monitoring)
# SENTRY_DSN=https://...@sentry.io/...

# =============================================================================
# OPTIONAL: Cloud Storage (Only if ENABLE_*_STORAGE=true)
# =============================================================================

# AWS S3 (if ENABLE_S3_STORAGE=true)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=receipt-extractor-uploads

# Google Drive (if ENABLE_GDRIVE_STORAGE=true)
# GOOGLE_CLIENT_ID=your_client_id
# GOOGLE_CLIENT_SECRET=your_client_secret
# GOOGLE_REDIRECT_URI=https://your-app.railway.app/auth/google/callback

# Dropbox (if ENABLE_DROPBOX_STORAGE=true)
# DROPBOX_APP_KEY=your_app_key
# DROPBOX_APP_SECRET=your_app_secret
# DROPBOX_REDIRECT_URI=https://your-app.railway.app/auth/dropbox/callback

# =============================================================================
# OPTIONAL: Cloud Training (Only if ENABLE_*_TRAINING=true)
# =============================================================================

# HuggingFace (if ENABLE_HF_TRAINING=true)
# HUGGINGFACE_TOKEN=hf_your_token_here
# HUGGINGFACE_SPACE_NAME=your-username/receipt-trainer

# Replicate (if ENABLE_REPLICATE_TRAINING=true)
# REPLICATE_API_TOKEN=your_token_here

# RunPod (if ENABLE_RUNPOD_TRAINING=true)
# RUNPOD_API_KEY=your_api_key_here
# RUNPOD_GPU_TYPE=NVIDIA_RTX_A5000

# =============================================================================
# ADVANCED: Rate Limiting & Security
# =============================================================================

# Rate Limiting (requests per minute)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60               # 60 requests per minute
RATE_LIMIT_PERIOD=60                 # Time window in seconds

# CORS (Cross-Origin Resource Sharing)
CORS_ENABLED=true
CORS_ORIGINS=https://your-app-name.railway.app,https://yourdomain.com

# Security Headers
SECURITY_HEADERS_ENABLED=true

# =============================================================================
# ADVANCED: Logging & Performance
# =============================================================================

# Logging
LOG_LEVEL=INFO                       # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json                      # json or text

# Performance
GUNICORN_WORKERS=4                   # Number of worker processes
GUNICORN_THREADS=2                   # Threads per worker
GUNICORN_TIMEOUT=120                 # Request timeout in seconds
GUNICORN_KEEPALIVE=5                 # Keep-alive timeout

# Celery (Background Tasks - Optional)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# END OF CONFIGURATION
# =============================================================================

# QUICK CHECKLIST:
# [ ] SECRET_KEY generated and set
# [ ] JWT_SECRET generated and set
# [ ] BASE_URL updated with your Railway app URL
# [ ] Stripe keys copied from dashboard
# [ ] Stripe product price IDs created and copied
# [ ] Stripe webhook configured
# [ ] SendGrid API key copied
# [ ] SendGrid sender email verified
# [ ] All variables copied to Railway dashboard
# [ ] PostgreSQL service added in Railway
# [ ] App deployed and health check passes

# TESTING:
# Visit: https://your-app-name.railway.app/api/health
# Should return: {"status": "healthy", "database": "connected"}

