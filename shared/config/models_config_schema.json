{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Models Configuration Schema",
  "description": "JSON schema for validating models_config.json",
  "type": "object",
  "required": ["available_models", "default_model"],
  "properties": {
    "available_models": {
      "type": "object",
      "description": "Dictionary of available models",
      "patternProperties": {
        "^[a-z0-9_]+$": {
          "type": "object",
          "required": ["id", "name", "type", "description"],
          "properties": {
            "id": {
              "type": "string",
              "description": "Unique identifier for the model"
            },
            "name": {
              "type": "string",
              "description": "Human-readable model name"
            },
            "type": {
              "type": "string",
              "enum": ["donut", "florence", "ocr", "easyocr", "paddle"],
              "description": "Model processor type"
            },
            "description": {
              "type": "string",
              "description": "Model description"
            },
            "huggingface_id": {
              "type": "string",
              "description": "HuggingFace model identifier (required for donut/florence)"
            },
            "task_prompt": {
              "type": "string",
              "description": "Task prompt for the model (required for donut/florence)"
            },
            "requires_auth": {
              "type": "boolean",
              "description": "Whether model requires authentication",
              "default": false
            },
            "capabilities": {
              "type": "object",
              "description": "Model capabilities",
              "properties": {
                "line_items": {
                  "type": "boolean",
                  "description": "Can extract individual line items"
                },
                "structured_output": {
                  "type": "boolean",
                  "description": "Outputs structured JSON"
                },
                "multilingual": {
                  "type": "boolean",
                  "description": "Supports multiple languages"
                }
              }
            }
          }
        }
      }
    },
    "default_model": {
      "type": "string",
      "description": "Default model to use if none specified"
    },
    "recommended_model": {
      "type": "string",
      "description": "Recommended model for best results"
    }
  }
}
