# =============================================================================
# Docker Ignore - Optimized for Production Deployment
# =============================================================================
# This file prevents unnecessary files from being copied to Docker image

# Git
.git
.gitignore
.github

# Python cache and bytecode
__pycache__
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
.Python

# Build artifacts
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache
nosetests.xml
coverage.xml
*.cover
.mypy_cache
tests/
tools/tests/
*.test.py
test_*.py

# Documentation (exclude all except README.md)
docs/
*.md
!README.md
ROADMAP.md
LICENSE
LICENSE.txt
CONTRIBUTING.md

# Logs
logs/
*.log

# Temporary files
*.tmp
temp/
tmp/

# Local development
*.local
*.local.*
.env.local
.env.*.local

# Models cache (large files)
models/
*.pt
*.pth
*.bin
*.onnx
*.pkl
*.safetensors

# Uploads and user data
uploads/
data/
datasets/
*.csv

# Database files
*.db
*.sqlite
*.sqlite3

# Desktop app (not needed for web deployment)
desktop/

# Tools (development only - not needed in production)
tools/

# Training modules (heavy, not needed for deployment)
web/backend/training/

# Benchmarks
tools/benchmarks/

# Examples
examples/

# Node modules (if any)
node_modules/

# Pre-commit hooks
.pre-commit-config.yaml

# Development scripts
launcher.sh
start.bat
git-sync.py
generate-secrets.py
