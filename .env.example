# =============================================================================
# Receipt Extractor - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection URL (production)
DATABASE_URL=postgresql://receipt_user:receipt_pass@localhost:5432/receipt_extractor

# Database connection pool settings
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Use SQLite for development/testing (set to 'true' to enable)
USE_SQLITE=false

# Enable SQL query logging (set to 'true' for debugging)
SQL_ECHO=false

# Enable serverless mode (NullPool for AWS Lambda, Cloud Run, etc.)
SERVERLESS=false

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT secret key (minimum 32 characters, use: openssl rand -base64 32)
JWT_SECRET=change-this-secret-in-production-use-env-var-min-32-chars

# JWT token expiration times (in seconds)
JWT_ACCESS_TOKEN_EXPIRES=900        # 15 minutes
JWT_REFRESH_TOKEN_EXPIRES=2592000   # 30 days

# =============================================================================
# STRIPE PAYMENT INTEGRATION
# =============================================================================
# Stripe API keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_test_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_publishable_key_here

# Stripe webhook secret (get from webhook configuration)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# =============================================================================
# HUGGINGFACE API
# =============================================================================
# HuggingFace API token (get from https://huggingface.co/settings/tokens)
# Required for accessing gated models and Inference API
HUGGINGFACE_API_KEY=hf_your_huggingface_token_here

# =============================================================================
# CLOUD STORAGE - AWS S3
# =============================================================================
# AWS credentials (get from AWS IAM)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# S3 bucket configuration
AWS_S3_BUCKET=receipt-extractor-images
AWS_REGION=us-east-1

# Optional: S3 endpoint for custom/local S3 (MinIO, LocalStack)
# AWS_S3_ENDPOINT=http://localhost:9000

# =============================================================================
# CLOUD STORAGE - GOOGLE DRIVE
# =============================================================================
# Google Drive OAuth 2.0 credentials (get from Google Cloud Console)
GOOGLE_DRIVE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_DRIVE_CLIENT_SECRET=your_client_secret_here
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# =============================================================================
# CLOUD STORAGE - DROPBOX
# =============================================================================
# Dropbox app credentials (get from https://www.dropbox.com/developers/apps)
DROPBOX_APP_KEY=your_dropbox_app_key
DROPBOX_APP_SECRET=your_dropbox_app_secret

# =============================================================================
# CLOUD TRAINING PROVIDERS
# =============================================================================
# Replicate API token (get from https://replicate.com/account)
REPLICATE_API_TOKEN=r8_your_replicate_token_here

# RunPod API key (get from https://www.runpod.io/console/user/settings)
RUNPOD_API_KEY=your_runpod_api_key_here

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================
# OpenTelemetry configuration
OTEL_SERVICE_NAME=receipt-extractor
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Enable Python logging auto-instrumentation
OTEL_PYTHON_LOGGING_AUTO_INSTRUMENTATION_ENABLED=false

# Sentry error tracking (get DSN from https://sentry.io)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# =============================================================================
# REDIS (OPTIONAL)
# =============================================================================
# Redis URL for rate limiting, caching, and job queue
# REDIS_URL=redis://localhost:6379/0

# For Upstash Redis (serverless):
# REDIS_URL=rediss://default:password@redis-host.upstash.io:6379

# =============================================================================
# FLASK APPLICATION SETTINGS
# =============================================================================
# Flask environment (development, production, testing)
FLASK_ENV=development

# Enable debug mode (NEVER use in production!)
DEBUG=true

# Flask secret key for sessions (generate with: python -c 'import secrets; print(secrets.token_hex())')
FLASK_SECRET_KEY=your_flask_secret_key_here

# =============================================================================
# CIRCULAR EXCHANGE FRAMEWORK
# =============================================================================
# Enable CEF webhook notifications (for CI/CD pipeline)
WEBHOOK_ENDPOINT_CEF=https://your-webhook-endpoint.com/cef

# =============================================================================
# TESTING & DEVELOPMENT
# =============================================================================
# Set to 'true' to enable test mode
TESTING=false

# Test database URL (optional - uses SQLite if not specified)
# TEST_DATABASE_URL=sqlite:///./test_receipt_extractor.db

# =============================================================================
# NOTES
# =============================================================================
# 1. Copy this file to .env in the same directory
# 2. Replace all placeholder values with your actual credentials
# 3. NEVER commit .env to version control (it's in .gitignore)
# 4. For production, use environment variables or secret management (AWS Secrets Manager, Vault, etc.)
# 5. Restart the application after changing environment variables
