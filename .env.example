# =============================================================================
# Receipt Extractor - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env with real credentials to version control!
#
# 🚨 CRITICAL SECURITY WARNINGS:
# =============================================================================
# 1. JWT_SECRET: MUST be changed from default! Anyone can forge tokens otherwise!
#    Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
#
# 2. SECRET_KEY: MUST be changed for production!
#    Generate: python -c "import secrets; print(secrets.token_hex(32))"
#
# 3. DATABASE_URL: MUST use PostgreSQL in production (NOT SQLite)!
#    SQLite will corrupt under load and concurrent users.
#
# 4. FLASK_DEBUG: MUST be False in production!
#    Debug mode exposes sensitive information and allows code execution.
#
# 5. BEFORE DEPLOYING, RUN:
#    python tools/validate_production_config.py --strict
#
# =============================================================================

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Flask Configuration
FLASK_ENV=development                    # Options: development, production
FLASK_DEBUG=False                        # Enable Flask debug mode (True/False)
DEBUG=False                              # General debug flag

# Server Configuration
# FLASK_HOST=0.0.0.0                     # Host to bind to (default: 0.0.0.0)
# FLASK_PORT=5000                        # Port to bind to (default: 5000)

# Serverless Deployment (AWS Lambda, Google Cloud Functions)
SERVERLESS=false                         # Set to true for serverless deployments

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database URL
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:password@localhost:5432/receipt_extractor

# SQLite fallback (for development/testing)
USE_SQLITE=false                         # Set to true to use SQLite instead of PostgreSQL
# DATABASE_URL=sqlite:///./receipt_extractor.db  # Uncomment if using SQLite

# Testing mode (uses in-memory SQLite)
TESTING=false                            # Set to true for testing

# Connection Pool Settings
DB_POOL_SIZE=5                           # Maximum number of connections in pool
DB_POOL_MAX_OVERFLOW=10                  # Extra connections when pool is full
DB_POOL_TIMEOUT=30                       # Seconds to wait for available connection
DB_POOL_RECYCLE=1800                     # Recycle connections every 30 minutes (seconds)

# SQL Debugging
SQL_ECHO=false                           # Log all SQL queries (True/False) - verbose!

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT Secret Key (🚨 CRITICAL - MUST CHANGE IN PRODUCTION!)
# Default value is a CRITICAL SECURITY VULNERABILITY!
# Anyone can forge authentication tokens and gain admin access!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-this-secret-in-production-use-env-var-min-32-chars

# JWT Token Expiration
JWT_ACCESS_TOKEN_EXPIRES=900             # Access token lifetime in seconds (15 minutes)
JWT_REFRESH_TOKEN_EXPIRES=2592000        # Refresh token lifetime in seconds (30 days)

# Password Hashing
# BCRYPT_LOG_ROUNDS=12                   # bcrypt complexity (higher = more secure but slower)

# =============================================================================
# STRIPE PAYMENT INTEGRATION (Planned Feature)
# =============================================================================
# Required for payment processing and subscription management
# Get keys from: https://dashboard.stripe.com/apikeys

# STRIPE_SECRET_KEY=sk_test_...          # Stripe secret key (test or live)
# STRIPE_PUBLISHABLE_KEY=pk_test_...     # Stripe publishable key (test or live)
# STRIPE_WEBHOOK_SECRET=whsec_...        # Webhook signing secret for security

# Stripe Product IDs (create in Stripe Dashboard)
# STRIPE_PRICE_ID_STARTER=price_...      # Starter plan price ID
# STRIPE_PRICE_ID_PRO=price_...          # Pro plan price ID
# STRIPE_PRICE_ID_ENTERPRISE=price_...   # Enterprise plan price ID

# =============================================================================
# CLOUD STORAGE PROVIDERS (Planned Feature)
# =============================================================================

# Feature Flags - Enable/disable cloud storage providers
# Set to false for MVP mode - local storage only
ENABLE_S3_STORAGE=false
ENABLE_GDRIVE_STORAGE=false
ENABLE_DROPBOX_STORAGE=false

# --- AWS S3 Storage ---
# Get credentials from: https://console.aws.amazon.com/iam/
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE      # AWS access key
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI...      # AWS secret key
# AWS_S3_BUCKET=receipt-extractor-images      # S3 bucket name
# AWS_REGION=us-east-1                        # AWS region

# --- Google Drive Integration ---
# Create OAuth 2.0 credentials: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_DRIVE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# --- Dropbox Integration ---
# Create app at: https://www.dropbox.com/developers/apps
# DROPBOX_APP_KEY=your-app-key
# DROPBOX_APP_SECRET=your-app-secret
# DROPBOX_ACCESS_TOKEN=sl.your-access-token   # Long-lived access token

# =============================================================================
# CLOUD TRAINING PROVIDERS (Planned Feature)
# =============================================================================

# Feature Flags - Enable/disable cloud training providers
# Set to false for MVP mode - local training only
ENABLE_HF_TRAINING=false
ENABLE_REPLICATE_TRAINING=false
ENABLE_RUNPOD_TRAINING=false

# --- HuggingFace API ---
# Get token from: https://huggingface.co/settings/tokens
# HUGGINGFACE_TOKEN=hf_...                    # HuggingFace API token (read/write access)

# --- Replicate API ---
# Get token from: https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN=r8_...                  # Replicate API token

# --- RunPod API ---
# Get API key from: https://www.runpod.io/console/user/settings
# RUNPOD_API_KEY=your-runpod-api-key
# RUNPOD_ENDPOINT_ID=your-endpoint-id         # Optional: specific GPU endpoint

# =============================================================================
# ANALYTICS & MONITORING (Planned Feature)
# =============================================================================

# OpenTelemetry Configuration
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318  # OTLP endpoint (gRPC or HTTP)
# OTEL_SERVICE_NAME=receipt-extractor                # Service name for tracing
# OTEL_ENVIRONMENT=development                       # Environment tag

# Sentry Error Tracking
# Get DSN from: https://sentry.io/settings/projects/
# SENTRY_DSN=https://...@sentry.io/...        # Sentry DSN for error tracking
# SENTRY_ENVIRONMENT=development              # Environment (development/staging/production)
# SENTRY_TRACES_SAMPLE_RATE=0.1               # Percentage of transactions to trace (0.0-1.0)

# =============================================================================
# CELERY & REDIS (Background Jobs)
# =============================================================================

# Redis URL for Celery broker and result backend
REDIS_URL=redis://localhost:6379/0

# Alternative: separate configuration
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=                            # Leave empty if no password

# Celery specific (optional - defaults to REDIS_URL)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# CIRCULAR EXCHANGE FRAMEWORK
# =============================================================================

# Enable/disable the Circular Exchange Framework (CEFR)
# Set to false for MVP mode - disables auto-tuning and runtime optimization
ENABLE_CEFR=false

# Framework Configuration
# CIRCULAR_EXCHANGE_ENABLED=true             # Enable/disable framework (legacy)
# CIRCULAR_EXCHANGE_LOG_LEVEL=INFO           # Framework logging level
# CIRCULAR_EXCHANGE_PERSISTENCE=redis        # Persistence backend (redis/file/memory)

# =============================================================================
# OCR & MODEL CONFIGURATION
# =============================================================================

# Model Cache Directory
# MODEL_CACHE_DIR=./models                   # Directory to cache downloaded models

# Tesseract OCR Path (auto-detected on most systems)
# TESSERACT_CMD=/usr/bin/tesseract           # Path to tesseract binary

# GPU Configuration
# CUDA_VISIBLE_DEVICES=0                     # GPU device ID(s) to use
# PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512  # PyTorch CUDA memory management

# Model Loading Limits
# MAX_LOADED_MODELS=3                        # Maximum number of models loaded in memory

# =============================================================================
# FILE UPLOAD SETTINGS
# =============================================================================

# Allowed file extensions (comma-separated)
# ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,bmp,tiff,webp,pdf

# Maximum file size (in bytes)
# MAX_CONTENT_LENGTH=16777216                # 16 MB default

# Upload directory
# UPLOAD_FOLDER=./uploads                    # Temporary upload directory

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log Level
# LOG_LEVEL=INFO                             # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Log Format
# LOG_FORMAT=json                            # Options: json, text

# Log Output
# LOG_FILE=./logs/app.log                    # Log file path (leave empty for stdout only)
# LOG_ROTATION=daily                         # Options: daily, size
# LOG_MAX_BYTES=10485760                     # Max log file size (10 MB) if LOG_ROTATION=size
# LOG_BACKUP_COUNT=5                         # Number of backup log files to keep

# =============================================================================
# CORS SETTINGS (Cross-Origin Resource Sharing)
# =============================================================================

# Allowed Origins (for web frontend)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080
# CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# RATE LIMITING (Planned Feature)
# =============================================================================

# Rate Limit Configuration
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE=100                  # Requests per minute per IP
# RATE_LIMIT_STORAGE=memory                  # Options: memory, redis

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================

# Profiling
# ENABLE_PROFILING=false                     # Enable performance profiling

# Mock External Services (for testing)
# MOCK_CLOUD_STORAGE=false                   # Use mock instead of real cloud storage
# MOCK_PAYMENT_PROCESSOR=false               # Use mock instead of real Stripe

# =============================================================================
# NOTES
# =============================================================================
#
# SECURITY BEST PRACTICES:
# - Use strong, randomly generated secrets for JWT_SECRET
# - Never commit .env files with real credentials
# - Use different credentials for development, staging, and production
# - Rotate API keys and secrets regularly
# - Use environment-specific .env files (.env.development, .env.production)
#
# PRODUCTION CHECKLIST:
# - Set FLASK_ENV=production
# - Set FLASK_DEBUG=False
# - Use PostgreSQL instead of SQLite
# - Enable HTTPS/TLS
# - Configure proper CORS_ORIGINS
# - Set up error tracking (Sentry)
# - Configure monitoring (OpenTelemetry)
# - Enable rate limiting
# - Use secure database connection (SSL)
# - Set strong JWT_SECRET (32+ characters)
#
# =============================================================================
