# =============================================================================
# RAILWAY DEPLOYMENT - REQUIRED ENVIRONMENT VARIABLES
# =============================================================================
# 
# This template shows exactly what environment variables need to be set in
# Railway dashboard for successful deployment.
#
# SETUP INSTRUCTIONS:
# 1. Run: python generate-secrets.py
# 2. Copy the generated SECRET_KEY and JWT_SECRET
# 3. Go to Railway dashboard → Your Service → Variables
# 4. Add these variables with the generated values
# 5. Deploy or redeploy your application
#
# =============================================================================

# =============================================================================
# CRITICAL VARIABLES - MUST BE SET FOR APP TO START
# =============================================================================

# Flask secret key for session security and CSRF protection
# MUST be at least 32 characters long
# Generate with: python generate-secrets.py
SECRET_KEY=REPLACE_WITH_SECRET_KEY_FROM_generate-secrets.py

# JWT token signing secret for authentication
# MUST be at least 32 characters long
# Generate with: python generate-secrets.py
JWT_SECRET=REPLACE_WITH_JWT_SECRET_FROM_generate-secrets.py

# =============================================================================
# AUTO-CONFIGURED BY RAILWAY
# =============================================================================

# Railway automatically provides these - DO NOT set manually:
# - PORT: Application port (Railway injects this)
# - DATABASE_URL: PostgreSQL connection string (if PostgreSQL service is linked)
# - RAILWAY_ENVIRONMENT: Deployment environment
# - RAILWAY_GIT_COMMIT_SHA: Git commit hash
# - RAILWAY_GIT_BRANCH: Git branch name

# =============================================================================
# FLASK CONFIGURATION
# =============================================================================

# Flask environment - use 'production' for Railway
FLASK_ENV=production

# Flask debug mode - MUST be False in production
FLASK_DEBUG=False

# =============================================================================
# OPTIONAL: PAYMENT PROCESSING
# =============================================================================

# Stripe API keys for payment processing
# Only required if you want to enable paid subscriptions
# Get from: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# OPTIONAL: EMAIL SERVICE
# =============================================================================

# SendGrid API key for sending emails (password resets, notifications)
# Only required if you want to enable email features
# Get from: https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=SG...
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# OPTIONAL: STORAGE PROVIDERS
# =============================================================================

# AWS S3 for cloud storage
# S3_BUCKET_NAME=your-bucket-name
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

# Google Drive API
# GOOGLE_DRIVE_CLIENT_ID=...
# GOOGLE_DRIVE_CLIENT_SECRET=...

# Dropbox API
# DROPBOX_APP_KEY=...
# DROPBOX_APP_SECRET=...

# =============================================================================
# OPTIONAL: AI/ML TRAINING PROVIDERS
# =============================================================================

# HuggingFace API for model training
# HUGGINGFACE_API_TOKEN=hf_...

# Replicate API for model training
# REPLICATE_API_TOKEN=r8_...

# RunPod API for GPU training
# RUNPOD_API_KEY=...

# =============================================================================
# DEPLOYMENT CHECKLIST
# =============================================================================
#
# Before deploying to Railway:
# ✅ 1. Generate secrets: python generate-secrets.py
# ✅ 2. Set SECRET_KEY in Railway dashboard
# ✅ 3. Set JWT_SECRET in Railway dashboard
# ✅ 4. Set FLASK_ENV=production
# ✅ 5. Set FLASK_DEBUG=False
# ✅ 6. (Optional) Link PostgreSQL database service
# ✅ 7. (Optional) Add Stripe keys if using payments
# ✅ 8. (Optional) Add SendGrid key if using emails
# ✅ 9. Deploy and monitor logs
# ✅ 10. Test health endpoint: curl https://your-app.railway.app/api/health
#
# =============================================================================

# =============================================================================
# TROUBLESHOOTING
# =============================================================================
#
# If health checks fail:
# 1. Check Railway logs for startup errors
# 2. Verify SECRET_KEY and JWT_SECRET are set (32+ chars each)
# 3. Check PORT is not manually set (Railway auto-provides it)
# 4. Verify DATABASE_URL format if using PostgreSQL
# 5. Check memory usage (should be < 512MB with 2 workers)
# 6. Review deployment logs for "STARTUP ERROR" messages
#
# Common errors:
# - "Missing required environment variable: SECRET_KEY" → Set SECRET_KEY in Railway
# - "Missing required environment variable: JWT_SECRET" → Set JWT_SECRET in Railway
# - "Health check timeout" → Check if app is binding to correct PORT
# - "OOM (Out of Memory)" → App is using too much RAM (reduce workers if needed)
#
# =============================================================================
