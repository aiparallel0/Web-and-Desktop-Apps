{
  "project": {
    "name": "Web-and-Desktop-Apps",
    "description": "Receipt OCR processing application with Circular Exchange Framework integration",
    "framework_version": "2.0.0"
  },
  "circular_exchange": {
    "description": "Central configuration and dependency management system",
    "core_components": [
      {
        "name": "PROJECT_CONFIG",
        "file": "shared/circular_exchange/project_config.py",
        "type": "singleton",
        "purpose": "Global configuration hub that propagates changes to all modules"
      },
      {
        "name": "VariablePackage",
        "file": "shared/circular_exchange/variable_package.py",
        "type": "class",
        "purpose": "Observable configuration values with change tracking and auto-tuning"
      },
      {
        "name": "PackageRegistry",
        "file": "shared/circular_exchange/variable_package.py",
        "type": "class",
        "purpose": "Registry for managing multiple VariablePackage instances"
      },
      {
        "name": "ModuleRegistration",
        "file": "shared/circular_exchange/project_config.py",
        "type": "dataclass",
        "purpose": "Module metadata for dependency tracking and change propagation"
      },
      {
        "name": "ChangeNotifier",
        "file": "shared/circular_exchange/change_notifier.py",
        "type": "class",
        "purpose": "Change event propagation system"
      },
      {
        "name": "DependencyRegistry",
        "file": "shared/circular_exchange/dependency_registry.py",
        "type": "class",
        "purpose": "Module dependency tracking"
      }
    ]
  },
  "modules": {
    "shared.models.ocr_processor": {
      "file_path": "shared/models/ocr_processor.py",
      "description": "Tesseract OCR-based receipt data extraction with early-exit optimization",
      "circular_exchange_integrated": true,
      "dependencies": [
        "shared.circular_exchange",
        "shared.utils.image_processing",
        "shared.utils.data_structures",
        "shared.models.ocr_common",
        "shared.models.ocr_config"
      ],
      "external_dependencies": [
        "pytesseract",
        "PIL",
        "cv2",
        "numpy"
      ],
      "exports": ["OCRProcessor"],
      "integration_details": {
        "uses_project_config": true,
        "uses_module_registration": true,
        "uses_package_registry": false,
        "uses_detection_config": true,
        "records_detection_results": true
      }
    },
    "shared.utils.image_processing": {
      "file_path": "shared/utils/image_processing.py",
      "description": "Image loading, validation, and preprocessing for OCR processing",
      "circular_exchange_integrated": true,
      "dependencies": [
        "shared.circular_exchange"
      ],
      "external_dependencies": [
        "PIL",
        "cv2",
        "numpy"
      ],
      "exports": [
        "load_and_validate_image",
        "enhance_image",
        "preprocess_for_ocr",
        "assess_image_quality",
        "get_image_config",
        "detect_text_regions",
        "preprocess_multi_pass"
      ],
      "configuration_packages": [
        {
          "name": "image.brightness_threshold",
          "default": 100,
          "validator": "0 <= v <= 255",
          "type": "int"
        },
        {
          "name": "image.contrast_threshold",
          "default": 40,
          "validator": "0 <= v <= 255",
          "type": "int"
        },
        {
          "name": "image.upscale_threshold",
          "default": 1000,
          "validator": "v >= 100",
          "type": "int"
        },
        {
          "name": "image.enhancement_factor",
          "default": 1.2,
          "validator": "0.5 <= v <= 3.0",
          "type": "float"
        }
      ]
    },
    "shared.models.ocr_config": {
      "file_path": "shared/models/ocr_config.py",
      "description": "OCR configuration with VariablePackage integration and auto-tuning",
      "circular_exchange_integrated": true,
      "dependencies": [
        "shared.circular_exchange.variable_package"
      ],
      "exports": [
        "OCRConfig",
        "get_ocr_config",
        "reset_ocr_config",
        "OCRPipelineStage"
      ],
      "configuration_packages": [
        {
          "name": "ocr.min_confidence",
          "default": 0.3,
          "validator": "0.0 <= v <= 1.0",
          "type": "float"
        },
        {
          "name": "ocr.relaxed_confidence",
          "default": 0.2,
          "validator": "0.0 <= v <= 1.0",
          "type": "float"
        },
        {
          "name": "ocr.relaxed_mode",
          "default": false,
          "type": "bool"
        },
        {
          "name": "ocr.auto_fallback",
          "default": true,
          "type": "bool"
        },
        {
          "name": "ocr.detection.min_confidence",
          "default": 0.25,
          "validator": "0.0 <= v <= 1.0",
          "type": "float"
        },
        {
          "name": "ocr.detection.box_threshold",
          "default": 0.3,
          "validator": "0.0 <= v <= 1.0",
          "type": "float"
        },
        {
          "name": "ocr.detection.min_text_height",
          "default": 8,
          "validator": "v >= 1",
          "type": "int"
        },
        {
          "name": "ocr.detection.auto_retry",
          "default": true,
          "type": "bool"
        }
      ],
      "features": {
        "auto_tuning": true,
        "pipeline_stages": true,
        "extraction_tracking": true,
        "detection_tracking": true
      }
    },
    "shared.models.ocr_common": {
      "file_path": "shared/models/ocr_common.py",
      "description": "Shared OCR utilities and pattern matching",
      "circular_exchange_integrated": true,
      "dependencies": [
        "shared.models.ocr_config"
      ],
      "exports": [
        "get_detection_config",
        "record_detection_result",
        "normalize_price",
        "extract_date",
        "extract_total",
        "extract_line_items",
        "parse_receipt_text",
        "clean_item_name"
      ]
    },
    "shared.utils.data_structures": {
      "file_path": "shared/utils/data_structures.py",
      "description": "Core data models for receipt processing",
      "circular_exchange_integrated": true,
      "dependencies": [
        "shared.circular_exchange"
      ],
      "exports": [
        "LineItem",
        "ReceiptData",
        "ExtractionResult",
        "ProcessingStatus"
      ]
    },
    "shared.utils.centralized_logging": {
      "file_path": "shared/utils/centralized_logging.py",
      "description": "Centralized logging system with structured output",
      "circular_exchange_integrated": true,
      "dependencies": [
        "shared.circular_exchange"
      ],
      "exports": [
        "get_logger",
        "configure_logging",
        "LogContext"
      ]
    },
    "shared.utils.errors": {
      "file_path": "shared/utils/errors.py",
      "description": "Error handling and custom exceptions",
      "circular_exchange_integrated": true,
      "dependencies": [
        "shared.circular_exchange"
      ],
      "exports": [
        "AppError",
        "OCRError",
        "ValidationError",
        "ImageProcessingError"
      ]
    },
    "shared.models.processors": {
      "file_path": "shared/models/processors.py",
      "description": "EasyOCR and PaddleOCR processors",
      "circular_exchange_integrated": false,
      "dependencies": [
        "shared.utils.image_processing",
        "shared.utils.data_structures",
        "shared.models.ocr_common"
      ],
      "external_dependencies": [
        "easyocr",
        "paddleocr",
        "PIL",
        "numpy"
      ],
      "exports": [
        "EasyOCRProcessor",
        "PaddleProcessor"
      ]
    },
    "shared.models.ai_models": {
      "file_path": "shared/models/ai_models.py",
      "description": "AI/ML models for advanced OCR (Florence-2)",
      "circular_exchange_integrated": false,
      "dependencies": [
        "shared.utils.image_processing",
        "shared.utils.data_structures"
      ],
      "external_dependencies": [
        "torch",
        "transformers",
        "PIL",
        "numpy"
      ],
      "exports": [
        "FlorenceProcessor"
      ]
    },
    "shared.models.model_manager": {
      "file_path": "shared/models/model_manager.py",
      "description": "Model lifecycle and memory management",
      "circular_exchange_integrated": false,
      "dependencies": [
        "shared.models.ocr_processor",
        "shared.models.processors",
        "shared.models.ai_models"
      ],
      "exports": [
        "ModelManager",
        "ProcessorType"
      ]
    },
    "shared.config.settings": {
      "file_path": "shared/config/settings.py",
      "description": "Project-wide settings",
      "circular_exchange_integrated": false,
      "exports": [
        "Settings",
        "get_settings"
      ]
    },
    "web-app.backend.app": {
      "file_path": "web-app/backend/app.py",
      "description": "Flask web application",
      "circular_exchange_integrated": false,
      "dependencies": [
        "shared.models.model_manager",
        "shared"
      ],
      "external_dependencies": [
        "flask",
        "flask_cors"
      ],
      "exports": [
        "app",
        "create_app"
      ]
    }
  },
  "dependency_graph": {
    "edges": [
      {"from": "shared.models.ocr_processor", "to": "shared.circular_exchange", "type": "framework"},
      {"from": "shared.models.ocr_processor", "to": "shared.utils.image_processing", "type": "import"},
      {"from": "shared.models.ocr_processor", "to": "shared.utils.data_structures", "type": "import"},
      {"from": "shared.models.ocr_processor", "to": "shared.models.ocr_common", "type": "import"},
      {"from": "shared.utils.image_processing", "to": "shared.circular_exchange", "type": "framework"},
      {"from": "shared.models.ocr_config", "to": "shared.circular_exchange.variable_package", "type": "framework"},
      {"from": "shared.models.ocr_common", "to": "shared.models.ocr_config", "type": "import"},
      {"from": "shared.utils.data_structures", "to": "shared.circular_exchange", "type": "framework"},
      {"from": "shared.utils.errors", "to": "shared.circular_exchange", "type": "framework"},
      {"from": "shared.utils.centralized_logging", "to": "shared.circular_exchange", "type": "framework"},
      {"from": "shared.models.processors", "to": "shared.utils.image_processing", "type": "import"},
      {"from": "shared.models.processors", "to": "shared.utils.data_structures", "type": "import"},
      {"from": "shared.models.processors", "to": "shared.models.ocr_common", "type": "import"},
      {"from": "shared.models.model_manager", "to": "shared.models.ocr_processor", "type": "import"},
      {"from": "shared.models.model_manager", "to": "shared.models.processors", "type": "import"},
      {"from": "shared.models.model_manager", "to": "shared.models.ai_models", "type": "import"},
      {"from": "web-app.backend.app", "to": "shared.models.model_manager", "type": "import"}
    ]
  },
  "integration_status": {
    "fully_integrated": [
      "shared/models/ocr_config.py",
      "shared/models/ocr_processor.py",
      "shared/models/ocr_common.py",
      "shared/utils/image_processing.py",
      "shared/utils/data_structures.py",
      "shared/utils/centralized_logging.py",
      "shared/utils/errors.py"
    ],
    "needs_integration": [
      "shared/models/ai_models.py",
      "shared/models/processors.py",
      "shared/models/model_manager.py",
      "shared/config/settings.py",
      "web-app/backend/app.py",
      "web-app/backend/auth.py",
      "web-app/backend/database.py"
    ]
  },
  "data_flow": {
    "receipt_processing": [
      {
        "step": 1,
        "module": "shared.utils.image_processing",
        "function": "load_and_validate_image",
        "input": "image_path",
        "output": "PIL.Image"
      },
      {
        "step": 2,
        "module": "shared.utils.image_processing",
        "function": "preprocess_for_ocr",
        "input": "PIL.Image",
        "output": "preprocessed PIL.Image"
      },
      {
        "step": 3,
        "module": "shared.models.ocr_processor",
        "function": "OCRProcessor.extract",
        "input": "image_path",
        "output": "ExtractionResult"
      },
      {
        "step": 4,
        "module": "shared.models.ocr_config",
        "function": "record_detection_result",
        "input": "detection metrics",
        "output": "auto-tuning update"
      }
    ]
  }
}
